{
  "title": "Sentiment Analysis",
  "tags": ["crypto", "sentiment", "news"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Sentiment Score Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PCC52D03280B7034C"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", score FROM crypto_sentiment_grafana ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": -0.1, "color": "orange"},
              {"value": 0.1, "color": "green"}
            ]
          },
          "min": -1,
          "max": 1
        }
      }
    },
    {
      "id": 2,
      "title": "News Articles with Sentiment",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "PCC52D03280B7034C"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"Time\", title AS \"Title\", source AS \"Source\", sentiment AS \"Sentiment\", score AS \"Score\" FROM crypto_sentiment_grafana ORDER BY time DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Sentiment"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": null, "color": "transparent"},
                    {"value": 0, "color": "red"},
                    {"value": 1, "color": "green"}
                  ]
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}
