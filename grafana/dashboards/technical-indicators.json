    {
      "id": 6,
      "title": "MACD",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", macd AS \"MACD Line\", macd_signal AS \"Signal Line\" FROM technical_indicators_grafana WHERE symbol = 'BITCOIN' ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}]}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "MACD Line"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]
          },
          {
            "matcher": {"id": "byName", "options": "Signal Line"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Bollinger Bands avec Prix",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", bb_upper AS \"Upper Band\", sma_20 AS \"SMA 20\", bb_lower AS \"Lower Band\" FROM technical_indicators_grafana WHERE symbol = 'BITCOIN' ORDER BY time",
          "refId": "A"
        },
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", price FROM crypto_prices_grafana WHERE symbol = 'BITCOIN' ORDER BY time",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}]},
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Upper Band"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.fillOpacity", "value": 10}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Lower Band"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}},
              {"id": "custom.fillOpacity", "value": 10}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "SMA 20"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}},
              {"id": "custom.lineWidth", "value": 3}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "price"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}},
              {"id": "custom.lineWidth", "value": 2}
            ]
          }
        ]
      }
    }
