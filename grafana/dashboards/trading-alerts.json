{
  "title": "Trading Alerts",
  "tags": ["crypto", "alerts", "trading"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "RSI Overbought Alert (RSI > 70)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", rsi, symbol FROM technical_indicators_grafana WHERE rsi > 70 ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 70, "color": "red"}
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "RSI Oversold Alert (RSI < 30)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", rsi, symbol FROM technical_indicators_grafana WHERE rsi < 30 ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "red"},
              {"value": 30, "color": "green"}
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "MACD Crossover Signals",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", macd AS \"MACD\", macd_signal AS \"Signal\", symbol FROM technical_indicators_grafana WHERE macd IS NOT NULL AND macd_signal IS NOT NULL ORDER BY time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Alerts Table",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "postgres"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT symbol AS \"Symbol\", time AS \"Time\", CASE WHEN rsi > 70 THEN 'Overbought' WHEN rsi < 30 THEN 'Oversold' ELSE 'Normal' END AS \"Alert Type\", rsi AS \"RSI\" FROM technical_indicators_grafana WHERE rsi > 70 OR rsi < 30 ORDER BY time DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}
